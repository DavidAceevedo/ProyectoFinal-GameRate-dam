{% extends 'base.html.twig' %}

{% block title %}Registro - GameRate{% endblock %}

{% block stylesheets %}
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        }

        body {
            background: radial-gradient(circle at top right, rgba(168, 85, 247, 0.05), transparent),
            #f3f4f6;
            min-height: 90vh;
        }

        .auth-card {
            border-radius: 25px !important;
            border: none;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .auth-header {
            background: var(--primary-gradient);
            border-radius: 25px 25px 0 0 !important;
            padding: 40px;
            text-align: center;
            color: white;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px 15px;
            border: 2px solid #e5e7eb;
            transition: all 0.3s;
        }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }

        .btn-register {
            background: var(--primary-gradient);
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 700;
            letter-spacing: 0.5px;
            transition: transform 0.3s;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3);
        }

        .auth-footer {
            text-align: center;
            margin-top: 20px;
            color: #6b7280;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
        <div class="col-md-5">
            <div class="card auth-card overflow-hidden">
                <div class="auth-header">
                    <h2 class="fw-bold mb-0">🎮 Únete a GameRate</h2>
                    <p class="small mb-0 opacity-75">Empieza a gestionar tu colección hoy mismo</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    {{ form_start(registrationForm) }}
                    <div class="mb-4">
                        {{ form_label(registrationForm.email, 'Correo Electrónico', {'label_attr': {'class': 'form-label fw-bold small text-uppercase'}}) }}
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'tu@email.com'}}) }}
                        <div class="text-danger small mt-1">
                            {{ form_errors(registrationForm.email) }}
                        </div>
                    </div>

                    <div class="mb-4">
                        {{ form_label(registrationForm.plainPassword, 'Contraseña', {'label_attr': {'class': 'form-label fw-bold small text-uppercase'}}) }}
                        {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Mínimo 6 caracteres'}}) }}
                        <div class="text-danger small mt-1">
                            {{ form_errors(registrationForm.plainPassword) }}
                        </div>
                    </div>

                    {# Si tienes un checkbox de aceptar términos, puedes añadirlo así: #}
                    {% if registrationForm.agreeTerms is defined %}
                        <div class="mb-4 form-check">
                            {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(registrationForm.agreeTerms, 'Acepto los términos y condiciones', {'label_attr': {'class': 'form-check-label small text-muted'}}) }}
                        </div>
                    {% endif %}

                    <button type="submit" class="btn btn-primary btn-register w-100 mt-2">
                        Crear mi cuenta 🚀
                    </button>
                    {{ form_end(registrationForm) }}

                    <div class="auth-footer">
                        <p class="mb-0 small">
                            ¿Ya tienes cuenta?
                            <a href="{{ path('app_login') }}" class="text-decoration-none fw-bold" style="color: #6366f1;">
                                Inicia sesión
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
